###############################################################
# Dockerfile.ghidra
#
# Mirrors the official Ghidra docker/Dockerfile structure
# (base → build → runtime) with two exceptions:
#   1. Auto-downloads latest (or pinned) Ghidra release from GitHub
#      instead of requiring a local release tree as build context.
#   2. Supports all MODEs in a single container (no restriction).
#
# Build:
#   docker build -f Dockerfile.ghidra -t ghidra .
#   docker build -f Dockerfile.ghidra --build-arg GHIDRA_VERSION=12.0.4 -t ghidra .
#
# Run (ghidra-server):
#   docker run --env MODE=ghidra-server -p 13100:13100 -p 13101:13101 -p 13102:13102 \
#     -v /path/to/my/repositories:/ghidra/repositories \
#     -v /path/to/my/server.conf:/ghidra/server/server.conf \
#     ghidra
###############################################################
FROM alpine:3.20 AS base

LABEL org.opencontainers.image.title="ghidra" \
	org.opencontainers.image.description="Docker image for Ghidra (auto-download)" \
	org.opencontainers.image.source="https://github.com/bolabaden/agentdecompile" \
	org.opencontainers.image.licenses="Apache 2.0"

ARG PUID="1001"
ARG PGID="1001"

# Configure user, entrypoint, and env vars first (before making the image larger)
# to keep image size as small as possible — matches official Ghidra Dockerfile.
RUN addgroup -g ${PGID} -S ghidra && adduser -u ${PUID} -S ghidra -G ghidra
ENTRYPOINT ["/bin/bash", "/ghidra/docker/entrypoint.sh"]
ENV JAVA_HOME=/usr/lib/jvm/java-21-openjdk
ENV LD_LIBRARY_PATH=/usr/lib/jvm/java-21-openjdk/lib/:/usr/lib/jvm/java-21-openjdk/lib/server/
WORKDIR /ghidra

# Dependencies used to both build and run ghidra — matches official list.
RUN apk update \
        && apk add openjdk21 python3 \
        bash gcompat \
        fontconfig msttcorefonts-installer \
        linux-headers libressl-dev \
        && update-ms-fonts

# ---- build stage: download Ghidra + build BSim postgres + install PyGhidra ----
FROM base AS build

# Optional: pin Ghidra release (e.g. "12.0.4"); omit for latest.
ARG GHIDRA_VERSION=""
ARG GHIDRA_OWNER="NationalSecurityAgency"
ARG GHIDRA_REPO="ghidra"

# Build dependencies — matches official list + curl/jq/unzip for auto-download.
RUN apk add gradle \
		python3-dev py-pip \
        alpine-sdk \
        build-base \
        gcc g++ make libc-dev zlib-dev musl-dev \
        zip readline-dev \
        curl jq unzip

# Auto-download Ghidra release from GitHub (exception #1 vs official Dockerfile
# which does COPY . . from a local release tree).
RUN set -eux; \
    GHIDRA_GITHUB_API="https://api.github.com/repos/${GHIDRA_OWNER}/${GHIDRA_REPO}"; \
    if [ -n "${GHIDRA_VERSION}" ]; then \
        API_URL="${GHIDRA_GITHUB_API}/releases/tags/Ghidra_${GHIDRA_VERSION}_build"; \
    else \
        API_URL="${GHIDRA_GITHUB_API}/releases/latest"; \
    fi; \
    echo "Fetching Ghidra release from ${API_URL}"; \
    BODY="$(curl -sSL -H 'Accept: application/vnd.github+json' "${API_URL}")"; \
    DOWNLOAD_URL="$(echo "${BODY}" | jq -r '.assets[] | select(.name | test("\\.zip$")) | select(.name | test("PUBLIC")) | .browser_download_url' | head -n 1)"; \
    if [ -z "${DOWNLOAD_URL}" ] || [ "${DOWNLOAD_URL}" = "null" ]; then \
        if [ -n "${GHIDRA_VERSION}" ]; then \
            GHIDRA_TAG="Ghidra_${GHIDRA_VERSION}_build"; \
        else \
            GHIDRA_TAG="$(curl -fsSLI -o /dev/null -w '%{url_effective}' "https://github.com/${GHIDRA_OWNER}/${GHIDRA_REPO}/releases/latest" | sed 's#.*/##')"; \
        fi; \
        RELEASE_PAGE="https://github.com/${GHIDRA_OWNER}/${GHIDRA_REPO}/releases/expanded_assets/${GHIDRA_TAG}"; \
        echo "GitHub API lookup failed, falling back to expanded assets scrape: ${RELEASE_PAGE}"; \
        DOWNLOAD_URL="$(curl -fsSL "${RELEASE_PAGE}" | sed -n 's/.*href="\([^"]*\/releases\/download\/[^"]*ghidra_[^"]*PUBLIC[^"]*\.zip\)".*/\1/p' | head -n 1)"; \
        case "${DOWNLOAD_URL}" in \
            http://*|https://*) ;; \
            /*) DOWNLOAD_URL="https://github.com${DOWNLOAD_URL}" ;; \
            *) DOWNLOAD_URL="" ;; \
        esac; \
    fi; \
    if [ -z "${DOWNLOAD_URL}" ] || [ "${DOWNLOAD_URL}" = "null" ]; then \
        echo "Could not determine Ghidra download URL from ${API_URL}"; exit 1; \
    fi; \
    echo "Downloading ${DOWNLOAD_URL}"; \
    curl -sSL -o /tmp/ghidra.zip "${DOWNLOAD_URL}"; \
    unzip -q -d /tmp/ghidra_extract /tmp/ghidra.zip; \
    mv /tmp/ghidra_extract/ghidra_* /ghidra/; \
    rm -f /tmp/ghidra.zip; \
    rm -rf /tmp/ghidra_extract

# Build BSim PostgreSQL + install PyGhidra into venv — matches official exactly.
RUN /ghidra/Ghidra/Features/BSim/support/make-postgres.sh \
        && python3 -m venv /ghidra/venv \
        && /ghidra/venv/bin/python3 -m pip install --no-index -f /ghidra/Ghidra/Features/PyGhidra/pypkg/dist pyghidra \
		&& mkdir -p /ghidra/repositories && mkdir -p /ghidra/bsim_datadir

# Build native decompiler/sleigh on arm64 (x86_64 ships prebuilt in the release).
RUN set -eux; \
    ARCH="$(uname -m)"; \
    OSDIR="linux_$(echo "${ARCH}" | sed 's/aarch64/arm_64/' | sed 's/x86_64/x86_64/')"; \
    NATIVE_DIR="/ghidra/Ghidra/Features/Decompiler/os/${OSDIR}"; \
    if [ -d "${NATIVE_DIR}" ] && [ -f "${NATIVE_DIR}/decompile" ]; then \
        echo "Native decompiler already present at ${NATIVE_DIR} — skipping build (${ARCH})"; \
    elif [ "${ARCH}" = "x86_64" ]; then \
        echo "x86_64 prebuilt binaries expected — skipping native build"; \
    else \
        echo "Platform ${ARCH} (${OSDIR}): building native decompiler from source..."; \
        cd /ghidra/Ghidra/Features/Decompiler/src/decompile/cpp; \
        mkdir -p ghi_opt sla_opt; \
        make OSDIR="${OSDIR}" ARCH_TYPE="" ghidra_opt sleigh_opt; \
        mkdir -p "${NATIVE_DIR}"; \
        cp ghidra_opt "${NATIVE_DIR}/decompile"; \
        cp sleigh_opt "${NATIVE_DIR}/sleigh"; \
        chmod +x "${NATIVE_DIR}/decompile" "${NATIVE_DIR}/sleigh"; \
        echo "Native binaries installed to ${NATIVE_DIR}"; \
        make clean; \
    fi

# Copy the entrypoint into the build tree so it gets COPY'd into runtime.
COPY docker/entrypoint-ghidra.sh /ghidra/docker/entrypoint.sh
RUN sed -i 's/\r$//' /ghidra/docker/entrypoint.sh && chmod +x /ghidra/docker/entrypoint.sh


# ---- runtime stage: slim image with only what's needed to run ----
FROM base AS runtime

# Runtime dependencies — matches official list.
RUN apk add openssl openssh-client \
        xhost musl-locales musl-locales-lang

USER ghidra
WORKDIR /ghidra
COPY --chown=ghidra:ghidra --from=build /ghidra /ghidra

EXPOSE 13100 13101 13102 5432
