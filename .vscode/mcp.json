{
  "servers": {
    "agdec-http": {
      "type": "http",
      "url": "http://${input:ad-http-host}:${input:ad-http-port}",
      "description": "Connect to existing AgentDecompile HTTP server (local PyGhidra mode)"
    },
    "agdec-http-shared": {
      "type": "http",
      "url": "http://${input:ad-http-host}:${input:ad-http-port}",
      "headers": {
        "User-Agent": "PyKotorAgent/1.0",
        "X-Agent-Server-Password": "${input:ghidra-server-password}",
        "X-Agent-Server-Repository": "${input:ghidra-server-repository}",
        "X-Agent-Server-Username": "${input:ghidra-server-username}",
        "X-Agent-Version": "1.0",
        "X-Ghidra-Server-Host": "${input:ad-http-ghidra-server-host}",
        "X-Ghidra-Server-Port": "${input:ad-http-ghidra-server-port}"
      },
      "description": "Connect to existing AgentDecompile HTTP server (shared Ghidra server mode)"
    },
    "agdec-stdio": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "git+https://github.com/bolabaden/agentdecompile",
        "agentdecompile-server",
        "--transport",
        "stdio"
      ],
      "description": "Spawn AgentDecompile server locally via stdio (local PyGhidra mode)"
    },
    "agdec-stdio-shared": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "git+https://github.com/bolabaden/agentdecompile",
        "agentdecompile-server",
        "--transport",
        "stdio"
      ],
      "env": {
        "AGENTDECOMPILE_GHIDRA_SERVER_HOST": "${input:ad-http-ghidra-server-host}",
        "AGENTDECOMPILE_GHIDRA_SERVER_PASSWORD": "${input:ghidra-server-password}",
        "AGENTDECOMPILE_GHIDRA_SERVER_PORT": "${input:ad-http-ghidra-server-port}",
        "AGENTDECOMPILE_GHIDRA_SERVER_REPOSITORY": "${input:ghidra-server-repository}",
        "AGENTDECOMPILE_GHIDRA_SERVER_USERNAME": "${input:ghidra-server-username}"
      },
      "description": "Spawn AgentDecompile server locally via stdio (shared Ghidra server mode)"
    },
    "agdec-stdio-proxy": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        "git+https://github.com/bolabaden/agentdecompile",
        "agentdecompile-server",
        "--transport",
        "stdio",
        "--mcp-server-url",
        "http://${input:ad-http-host}:${input:ad-http-port}"
      ],
      "description": "Spawn local proxy via stdio that forwards to remote AgentDecompile server"
    }
  },
  "inputs": [
    {
      "id": "ad-http-host",
      "type": "promptString",
      "description": "Hostname for the Agent Decompile HTTP server",
      "default": "localhost"
    },
    {
      "id": "ad-http-port",
      "type": "promptString",
      "description": "Port for the Agent Decompile HTTP server",
      "default": "8080"
    },
    {
      "id": "ad-http-ghidra-server-host",
      "type": "promptString",
      "description": "Hostname for the Ghidra server (used by the Agent Decompile HTTP server)",
      "default": "localhost"
    },
    {
      "id": "ad-http-ghidra-server-port",
      "type": "promptString",
      "description": "Port for the Ghidra server (used by the Agent Decompile HTTP server)",
      "default": "13100"
    },
    {
      "id": "ghidra-server-username",
      "type": "promptString",
      "description": "Username for authenticating with the Ghidra server",
      "default": "OpenKotOR"
    },
    {
      "id": "ghidra-server-password",
      "type": "promptString",
      "description": "Password for authenticating with the Ghidra server",
    },
    {
      "id": "ghidra-server-repository",
      "type": "promptString",
      "description": "Ghidra repository to use for decompilation",
      "default": ""
    }
  ]
}
