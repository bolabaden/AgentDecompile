{
  "servers": {
    "agentdecompile-shared": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        ".",
        "--with-editable",
        ".",
        "agentdecompile-server",
        "--transport",
        "stdio",
        "--ghidra-server-host",
        "170.9.241.140",
        "--server-username",
        "${input:ghidra-username}",
        "--server-password",
        "${input:ghidra-password}",
        "--ghidra-server-repository",
        "Odyssey"
      ],
      "env": {
        "AGENTDECOMPILE_ENABLE_LEGACY_TOOLS": "1",
        "AGENTDECOMPILE_DISABLE_TOOLS": "get-functions,manage-bookmarks,manage-comments,manage-data-types,manage-files,manage-function,manage-strings,manage-structures,manage-symbols"
      }
    }
  },
  "inputs": [
    {
      "id": "ghidra-username",
      "type": "promptString",
      "description": "Ghidra shared server username"
    },
    {
      "id": "ghidra-password",
      "type": "promptString",
      "description": "Ghidra shared server password",
      "password": true
    }
  ]
}
