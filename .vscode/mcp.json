{
  "servers": {
    "agentdecompile-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--from",
        ".",
        "--with-editable",
        ".",
        "agentdecompile-server",
        "--transport",
        "stdio",
        "--ghidra-server-host",
        "170.9.241.140",
        "--server-username",
        "${input:ghidra-username}",
        "--server-password",
        "${input:ghidra-password}",
        "--ghidra-server-repository",
        "Odyssey"
      ]
    }
  },
  "inputs": [
    {
      "id": "ghidra-username",
      "type": "promptString",
      "description": "Ghidra shared server username"
    },
    {
      "id": "ghidra-password",
      "type": "promptString",
      "description": "Ghidra shared server password",
      "password": true
    }
  ]
}
